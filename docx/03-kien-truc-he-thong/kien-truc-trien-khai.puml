@startuml
skinparam backgroundColor white
skinparam shadowing false
skinparam ArrowColor #475569
skinparam nodeBorderColor #1F2937
skinparam databaseBorderColor #1F2937
skinparam cloudBorderColor #1F2937

actor "Nguoi dung" as EndUser

node "Browser" as Browser
node "Docker Compose" {
  node "web\nNginx + Frontend" as Web
  node "api\nExpress + Socket.IO" as Api
  database "db\nPostgreSQL 15" as Db
  node "redis\nRedis 7" as Cache
}

cloud "Swagger UI\n/api-docs" as Swagger
cloud "Healthcheck\n/health" as Health

EndUser --> Browser
Browser --> Web : HTTP 80
Web --> Api : /api
Browser --> Api : WebSocket / realtime
Api --> Db : Sequelize
Api --> Cache : Redis client
Browser --> Swagger
Swagger --> Api
Browser --> Health
Health --> Api

note right of Api
Cong chinh:
- 5000 backend
- auth, wallets, transactions
- families, goals, reports
- admin, forecast
end note

note bottom of Web
Frontend route:
/, /transactions, /wallets,
/goals, /family, /reports,
/settings, /profile, /forecast, /admin
end note
@enduml
