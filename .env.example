# ┌────────────────────────────────────────────────────┐
# │  Junkio Expense Tracker - Environment Template     │
# │  Copy file này thành .env và điền giá trị thật     │
# │  $ cp .env.example .env                            │
# └────────────────────────────────────────────────────┘

# ── Database (PostgreSQL) ──
POSTGRES_USER=admin
POSTGRES_PASSWORD=<your-db-password>
POSTGRES_DB=expense_tracker_db

DB_HOST=db
DB_USER=admin
DB_PASS=<your-db-password>
DB_NAME=expense_tracker_db

# ── Backend ──
PORT=5000
JWT_SECRET=<generate-a-strong-random-secret>
JWT_REFRESH_SECRET=<generate-a-strong-random-refresh-secret>
VITE_FRONTEND_URL=http://localhost
AUTO_SEED=false

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── Email (SMTP - bắt buộc ở production) ──
EMAIL_HOST=<smtp-host>
EMAIL_PORT=587
EMAIL_USER=<smtp-user>
EMAIL_PASS=<smtp-password>
