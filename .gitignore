# Ignore dependencies
node_modules/
/backend/node_modules/
/frontend/node_modules/

# Ignore database state
postgres_data/

# Ignore environment files
.env
!.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore frontend build output
frontend/dist/

# Ignore logs
*.log
backend/error.log

# Ignore test and debug output
test_*.js
*_test.js
**/test-results.json
security_*.txt

# Ignore build and lint output
**/build_*.txt
**/build.log
**/lint_*.txt
**/lint_*.json
lint*.json
phaseC-*.txt

# Ignore docs by default but keep QA artifacts tracked
doc/*
!doc/qa/
!doc/qa/**

# Ignore temporary and local Postman workspace state
tmp/
.postman/
postman/

# Ignore QA/browser artifacts
output/
frontend/playwright-report/
frontend/test-results/

# Ignore generated export artifacts
frontend/transactions_*.pdf
frontend/transactions_*.csv
frontend/transactions_*.xlsx

# Ignore agent folders
.agent/
.agents/
_agent/
_agents/
.playwright-cli/
.gemini/

# Ignore backend testing logs and outputs
backend/*-log.txt
backend/*_error.txt
backend/final_test.txt
backend/parse_output.txt
backend/test_results.txt
backend/jest*.json
backend/jest*.txt

# Ignore agent and AI tool folders
.ai-devkit.json

# Ignore additional frontend reports
frontend/report_*.*
