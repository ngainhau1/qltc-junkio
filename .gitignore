# Ignore dependencies
node_modules/
/backend/node_modules/
/frontend/node_modules/

# Ignore database state
postgres_data/

# Ignore environment files
.env

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore frontend build output
frontend/dist/

# Ignore logs
*.log
backend/error.log

# Ignore test and debug output
test_*.js
*_test.js
**/test-results.json
security_*.txt

