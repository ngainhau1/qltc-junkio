PORT=5000
DB_HOST=localhost
DB_USER=admin
DB_PASS=password123
DB_NAME=expense_tracker_db
JWT_SECRET=<generate-your-secret>
JWT_REFRESH_SECRET=<generate-your-refresh-secret>
REDIS_HOST=localhost
REDIS_PORT=6379
# Enable SQL logs & timing (dev only)
SEQUELIZE_LOG=false
VITE_FRONTEND_URL=http://localhost

# SMTP cấu hình (bắt buộc ở production)
EMAIL_HOST=<smtp-host>
EMAIL_PORT=587
EMAIL_USER=<smtp-user>
EMAIL_PASS=<smtp-password>

# Chỉ seed demo khi biến này = true
AUTO_SEED=false
